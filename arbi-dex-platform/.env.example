# Базовый URL API (как в arbiDexClientFront)
# Dev: /api — через Vite proxy (см. vite.config.ts)
VITE_API_BASE_URL=/api

# Куда проксировать /api в dev
VITE_API_PROXY_TARGET=http://localhost:3006

# Store API — market data (POST /market-api/store/keys через Vite proxy)
VITE_STORE_API_BASE=/market-api
VITE_STORE_API_PROXY_TARGET=http://89.125.68.35:3002

# Альтернатива: через arbi-dex-server (нужен MARKET_DATA_URL на сервере)
# VITE_STORE_API_BASE=/api/store
VITE_STORE_API_PROXY_TARGET=http://89.125.68.35:3002

# Прямой URL store API (без proxy):
# VITE_STORE_API_BASE=http://89.125.68.35:3002
