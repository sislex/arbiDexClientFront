{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": ["ts-jest", { "tsconfig": "<rootDir>/../tsconfig.json" }]
  },
  "transformIgnorePatterns": [
    "node_modules/(?!(uuid|ethers|@ethersproject)/)"
  ],
  "testTimeout": 60000
}
