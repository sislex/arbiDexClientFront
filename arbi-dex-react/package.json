{
  "name": "arbi-dex-react",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "storybook": "storybook dev -p 6007 --no-open",
    "build-storybook": "storybook build",
    "test:sb": "npm run build-storybook && concurrently -k -s first \"http-server storybook-static -p 6007 -a 127.0.0.1 --silent\" \"wait-on tcp:127.0.0.1:6007 && test-storybook --url http://127.0.0.1:6007 --maxWorkers=2\"",
    "test:live": "VITE_API_BASE_URL=http://localhost:3006/api vite-node scripts/live-smoke.ts",
    "dev:live": "VITE_API_BASE_URL=http://localhost:3006/api vite",
    "dev:e2e": "VITE_API_BASE_URL=http://localhost:3006/api vite --port 5399 --strictPort",
    "e2e": "playwright test -c e2e/playwright.config.ts"
  },
  "dependencies": {
    "@emotion/react": "^11.13.5",
    "@emotion/styled": "^11.13.5",
    "@fontsource/inter": "^5.1.0",
    "@mui/icons-material": "^6.1.9",
    "@mui/material": "^6.1.9",
    "@reduxjs/toolkit": "^2.4.0",
    "ethers": "^6.17.0",
    "lightweight-charts": "^4.2.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-redux": "^9.2.0",
    "react-router-dom": "^6.28.0",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@storybook/addon-essentials": "^8.4.7",
    "@storybook/blocks": "^8.4.7",
    "@storybook/react": "^8.4.7",
    "@storybook/react-vite": "^8.4.7",
    "@storybook/test": "^8.4.7",
    "@storybook/test-runner": "^0.21.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "http-server": "^14.1.1",
    "storybook": "^8.4.7",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-node": "^2.1.9",
    "wait-on": "^8.0.1"
  }
}
